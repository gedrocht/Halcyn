PROJECT_NAME           = "Halcyn"
PROJECT_BRIEF          = "GPU-rendered JSON-driven 2D and 3D graphics viewer with an HTTP API"
OUTPUT_DIRECTORY       = docs/generated
CREATE_SUBDIRS         = NO
ALLOW_UNICODE_NAMES    = YES
OUTPUT_LANGUAGE        = English
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = NO
ALWAYS_DETAILED_SEC    = YES
INLINE_INHERITED_MEMB  = YES
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO
EXTENSION_MAPPING      =
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
BUILTIN_STL_SUPPORT    = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = NO
SHOW_INCLUDE_FILES     = YES
INLINE_INFO            = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_MEMBERS_CTORS_1ST = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
SOURCE_BROWSER         = YES
GENERATE_HTML          = YES
HTML_OUTPUT            = code-reference
HTML_COLORSTYLE        = TOGGLE
GENERATE_TREEVIEW      = YES
GENERATE_LATEX         = NO
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
INPUT                  = README.md docs/doxygen src
FILE_PATTERNS          = *.md *.hpp *.cpp
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */docs/generated/*
USE_MDFILE_AS_MAINPAGE = docs/doxygen/mainpage.md
