root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ps1,bat,cmd}]
end_of_line = crlf

[*.{cpp,hpp,h,cc,c,cmake}]
indent_style = space
indent_size = 2

[*.{py,yml,yaml,json,md,html,css,js,txt}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
